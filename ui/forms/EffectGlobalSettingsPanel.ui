<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>EffectGlobalSettingsPanel</class>
 <widget class="QGroupBox" name="EffectGlobalSettingsPanel">
  <property name="title">
   <string>Effect global settings</string>
  </property>
  <property name="visible">
   <bool>false</bool>
  </property>
  <property name="toolTip">
   <string>Same controls as other stack effects: stack layer and zone apply to the selected layer. Effect center is applied globally to every running layer when the stack renders (see RenderEffectStack).</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <property name="spacing">
    <number>6</number>
   </property>
   <item>
    <layout class="QHBoxLayout" name="effectRow">
     <item>
      <widget class="QLabel" name="effectRowLabel">
       <property name="text">
        <string>Effect:</string>
       </property>
       <property name="toolTip">
        <string>Which stack layer is active for editing and preview (same list as Effect Layers on the left).</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="effectCombo"/>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="zoneRow">
     <item>
      <widget class="QLabel" name="zoneLabel">
       <property name="text">
        <string>Zone:</string>
       </property>
       <property name="toolTip">
        <string>Which LEDs this stack layer considers: all controllers, one zone, or one controller. Pair with Target bounds: zone bounds remap pattern coordinates into that box (good for strips or partial rooms); per-effect placement and coverage stay under Effect Controls (geometry and Scale).</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="zoneCombo"/>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="originRow">
     <item>
      <widget class="QLabel" name="originLabel">
       <property name="text">
        <string>Spatial anchor:</string>
       </property>
       <property name="toolTip">
        <string>Where patterns attach in space for this layer. Room box center maps across the full room; other anchors use origin-based coordinates (see Room output below).</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="originCombo"/>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="boundsRow">
     <item>
      <widget class="QLabel" name="boundsLabel">
       <property name="text">
        <string>Target bounds:</string>
       </property>
       <property name="toolTip">
        <string>Which coordinate span the effect samples for this layer: full room/world grid, or the selected target's axis-aligned box. Does not replace per-effect geometry (center offset, axis scale, rotations, Scale slider).</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="boundsCombo"/>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QWidget" name="roomOutputSection" native="true">
     <layout class="QVBoxLayout" name="roomOutputSectionLayout">
      <property name="leftMargin">
       <number>0</number>
      </property>
      <property name="topMargin">
       <number>4</number>
      </property>
      <property name="rightMargin">
       <number>0</number>
      </property>
      <property name="bottomMargin">
       <number>0</number>
      </property>
      <property name="spacing">
       <number>4</number>
      </property>
      <item>
       <widget class="QLabel" name="roomOutputSectionLabel">
        <property name="text">
         <string>Room output:</string>
        </property>
        <property name="toolTip">
         <string>How this layer paints the room: direct on its zone, or emitter + relay mirror. Use Spatial anchor above for effect-origin vs room-mapped coordinates.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QWidget" name="roomOutputHost" native="true"/>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QComboBox" name="stackEffectTypeCombo">
     <property name="visible">
      <bool>false</bool>
     </property>
     <item>
      <property name="text">
       <string>None</string>
      </property>
     </item>
    </widget>
   </item>
   <item>
    <widget class="QComboBox" name="stackEffectZoneCombo">
     <property name="visible">
      <bool>false</bool>
     </property>
     <item>
      <property name="text">
       <string>All Controllers</string>
      </property>
     </item>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
