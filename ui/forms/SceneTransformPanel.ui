    <widget class="EffectInfoLabel" name="transformHelpLabel" native="true">
     <property name="text">
      <string>Moves the selected controller, reference point, or display plane in the room (your layout). Does not change the camera view. Spin boxes set absolute position in mm. Drag a position slider handle to move smoothly across the room (full width/height/depth per drag); Shift = finer, Ctrl = medium; wheel = 0.1 mm steps. Axes: X = width, Y = height, Z = depth. Rotation in degrees.</string>
     </property>
